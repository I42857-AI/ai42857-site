        "priority": "P1", "scope": "general", "frequency": "medium"
      },
      "CangQiong": {
        "zh": "苍穹", "pinyin": "CangQiong", "en": "CangQiong (Firmament)",
        "definition": "系统托盘应用，统一管理所有应用脚本和 Agent，自动发现+一键启动",
        "priority": "P1", "scope": "general", "frequency": "medium"
      },
      "SanCengYingShe": {
        "zh": "三层映射", "pinyin": "SanCengYingShe", "en": "Three-Layer Mapping",
        "definition": "4.0 架构三层：用户配置层(Z:\\PC) / 漫游数据层(credentials) / 应用管理层(XiangMu-KongJian)",
        "priority": "P1", "scope": "general", "frequency": "medium"
      },
      "ZiJiSymlink": {
        "zh": "子级Symlink", "pinyin": "ZiJiSymlink", "en": "Sub-level Symlink",
        "definition": "C:\\Users\\PC 是真实目录时，在内部创建的 Symlink（如 .trae-cn、.qclaw），实现路径重定向",
        "priority": "P1", "scope": "general", "frequency": "high"
      }
    },
