    "usage": "翻译前/新会话启动时读取此文件。翻译完成后将新术语追加入此文件。概念查询时按 pinyin 或 en 字段检索。",
    "priorityDefinition": "P0=系统级核心(所有Agent必知) P1=架构级(理解4.0必知) P2=脚本级(写脚本必知) P3=运维级(日常运维必知) P4=项目专用(特定项目才需) P5=低频参考",
    "scopeDefinition": "general=通用词(跨项目) project=项目专用词(特定项目)"
  },
  "concepts": {
    "_P0_XiTong": {
      "_desc": "P0 系统级核心 — 所有 Agent 必知，不理解则无法工作",
      "ChongDongHua": {
        "zh": "虫洞化", "pinyin": "ChongDongHua", "en": "Wormhole / Symlink Mapping",
        "definition": "通过 Symlink 将 C 盘路径映射到移动盘，使应用无感知地读写移动盘数据",
        "priority": "P0", "scope": "general", "frequency": "high"
      },
      "PCYu": {
        "zh": "PC域", "pinyin": "PCYu", "en": "PC Domain",
        "definition": "4.0 核心架构，C:\\Users\\PC 作为独立用户域，等效于 Z 盘化",
        "priority": "P0", "scope": "general", "frequency": "high"
      },
      "ZPanGuDingHua": {
        "zh": "Z盘化", "pinyin": "ZPanGuDingHua", "en": "Z-Drive Fixation",
        "definition": "将移动盘盘符固定为 Z:，确保所有脚本和 Symlink 路径一致",
        "priority": "P0", "scope": "general", "frequency": "high"
      },
      "XiangMuKongJian": {
        "zh": "项目空间", "pinyin": "XiangMuKongJian", "en": "Project Space",
        "definition": "Z:\\XiangMu-KongJian\\，移动盘上的应用管理层，各应用目录的父目录",
        "priority": "P0", "scope": "general", "frequency": "high"
      },
      "YiDongPan": {
        "zh": "移动盘", "pinyin": "YiDongPan", "en": "Removable Drive",
        "definition": "唯一真实数据源，所有关键数据存储于此，盘符固定为 Z:",
        "priority": "P0", "scope": "general", "frequency": "high"
      }
    },
    "_P1_JiaGou": {
      "_desc": "P1 架构级 — 理解 4.0 架构必知",
      "ChuShiJi": {
        "zh": "初始机", "pinyin": "ChuShiJi", "en": "Primary Machine",
        "definition": "公司设备，C:\\Users\\PC 是 Windows 注册用户（真实目录），子级 Symlink 处理重定向",
        "priority": "P1", "scope": "general", "frequency": "high"
      },
      "BeiYongJi": {
        "zh": "备用机", "pinyin": "BeiYongJi", "en": "Secondary Machine",
        "definition": "家庭/网吧/其他设备，C:\\Users\\PC 可能是 Symlink 或真实目录",
        "priority": "P1", "scope": "general", "frequency": "high"
      },
      "DaXiaoZhou": {
        "zh": "大小周", "pinyin": "DaXiaoZhou", "en": "Alternating Work Weeks",
        "definition": "大周双休+小周单休交替。小周周六=初始机，大周周六=备用机",
        "priority": "P1", "scope": "general", "frequency": "medium"
      },
      "ShouLian": {
        "zh": "收敛", "pinyin": "ShouLian", "en": "Convergence",
