                                   "ecosystem",
                                   "developer",
                                   "unique"
                               ],
                      "complexity":  "complex"
                  },
                  {
                      "id":  "concept:library-system",
                      "type":  "concept",
                      "name":  "资源库管理系统",
                      "summary":  "Eagle 核心数据管理模型。每个资源库以 .library 后缀文件夹存储，内含 metadata.json（项目元数据）、缩略图缓存、原始文件副本。支持多资源库切换、合并、密码保护。智能文件夹通过规则引擎自动归类。标签系统支持群组、常用标签、自动标签（按文件夹自动添加）。未分类/未标签视图帮助整理遗漏",
                      "tags":  [
                                   "library",
                                   "metadata",
                                   "folder",
                                   "tag",
                                   "organization"
                               ],
                      "complexity":  "complex"
                  },
                  {
                      "id":  "concept:thumbnail-engine",
                      "type":  "concept",
                      "name":  "多格式缩略图引擎",
                      "summary":  "Eagle 支持 90+ 文件格式的缩略图生成和预览。图像类：jpg/png/gif/webp/psd/ai/svg/raw/heic/avif 等通过 Magick.dll 和自定义模块处理；视频类：mp4/mov/avi/webm 等通过 ffmpeg.dll 帧提取；Office 类：docx/xlsx/pptx 通过 libOffice.dll 渲染；字体类：ttf/otf 通过 opentype 渲染预览；3D 模型：通过 model-thumbnail 模块。不支持格式可通过插件扩展",
                      "tags":  [
                                   "thumbnail",
